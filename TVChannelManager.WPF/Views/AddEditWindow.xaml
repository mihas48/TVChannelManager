<Window x:Class="TVChannelManager.WPF.Views.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить / редактировать канал"
        Height="620" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF4FF">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="BorderBrush"              Value="#90CAF9"/>
            <Setter Property="BorderThickness"          Value="1.5"/>
            <Setter Property="Background"               Value="#F5F9FF"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1565C0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0A3070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E3EEFF"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                BorderBrush="#90CAF9" BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Margin="24" Background="White" CornerRadius="10" Padding="24,20">
            <Border.Effect>
                <DropShadowEffect Color="#1565C0" BlurRadius="14" ShadowDepth="0" Opacity="0.14"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="WindowTitleLabel"
                           Text="Новый телеканал"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#1565C0"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Название канала" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>

                <TextBlock Text="Рейтинг (0 – 100)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="RatingBox" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>

                <TextBlock Text="Средний возраст зрителей" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="AgeBox" Style="{StaticResource InputBox}" Margin="0,0,0,14"/>

                <TextBlock Text="Дата основания" Style="{StaticResource FieldLabel}"/>
                <DatePicker x:Name="FoundingDatePicker"
                            Height="34" FontSize="13"
                            BorderBrush="#90CAF9" BorderThickness="1.5"
                            Background="#F5F9FF"
                            Margin="0,0,0,14"/>

                <TextBlock Text="Время начала вещания (ЧЧ:ММ)" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="BroadcastTimeBox"
                         Style="{StaticResource InputBox}"
                         Margin="0,0,0,14"/>

                <CheckBox x:Name="IsHDCheckBox"
                          Content="HD-вещание"
                          FontSize="13" Foreground="#1565C0"
                          FontWeight="SemiBold" Cursor="Hand"
                          Margin="0,0,0,14"/>

                <TextBlock Text="Жанр канала" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="GenreComboBox"
                          Height="34" FontSize="13"
                          BorderBrush="#90CAF9" BorderThickness="1.5"
                          Background="#F5F9FF"
                          Margin="0,0,0,14">
                    <ComboBoxItem Content="Новостной"       Tag="Новостной"/>
                    <ComboBoxItem Content="Развлекательный" Tag="Развлекательный"/>
                    <ComboBoxItem Content="Спортивный"      Tag="Спортивный"/>
                    <ComboBoxItem Content="Детский"         Tag="Детский"/>
                    <ComboBoxItem Content="Документальный"  Tag="Документальный"/>
                    <ComboBoxItem Content="Музыкальный"     Tag="Музыкальный"/>
                </ComboBox>

                <TextBlock Text="Логотип канала" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#F5F9FF"
                            BorderBrush="#90CAF9" BorderThickness="1.5"
                            CornerRadius="5" Height="80">
                        <Image x:Name="LogoPreview"
                               Stretch="Uniform"
                               Margin="4"/>
                    </Border>
                    <Button Grid.Column="2"
                            Content="📁 Выбрать файл"
                            Style="{StaticResource SecondaryBtn}"
                            Width="130" Height="34"
                            VerticalAlignment="Center"
                            Padding="0"
                            Click="ChooseImageButton_Click"/>
                </Grid>
                <TextBlock x:Name="ImagePathLabel"
                           Text="Файл не выбран"
                           FontSize="11" Foreground="#90A4AE"
                           Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Отмена"
                            Style="{StaticResource SecondaryBtn}"
                            Padding="0"
                            Click="CancelButton_Click"/>
                    <Button Grid.Column="2"
                            Content="Сохранить"
                            Style="{StaticResource PrimaryBtn}"
                            Padding="0"
                            Click="SaveButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>