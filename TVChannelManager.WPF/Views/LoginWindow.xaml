<Window x:Class="TVChannelManager.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TVChannel Manager — Вход"
        Height="420" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EEF4FF">

    <Window.Resources>
        <Style x:Key="GreenBtn" TargetType="Button">
            <Setter Property="Background"     Value="#1565C0"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"         Value="38"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0A3070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="OutlineBtn" TargetType="Button" BasedOn="{StaticResource GreenBtn}">
            <Setter Property="Background"     Value="#E3EEFF"/>
            <Setter Property="Foreground"     Value="#1565C0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                BorderBrush="#90CAF9" BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Width="380" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White" CornerRadius="12" Padding="32,28">
            <Border.Effect>
                <DropShadowEffect Color="#1565C0" BlurRadius="18" ShadowDepth="0" Opacity="0.18"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="📺  TV CHANNEL MANAGER"
                           FontSize="18" FontWeight="Bold" Foreground="#1565C0"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Авторизация"
                           FontSize="13" Foreground="#64B5F6"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Имя пользователя" FontSize="12" Foreground="#1565C0"
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="LoginBox"
                         Height="36" FontSize="13"
                         BorderBrush="#90CAF9" BorderThickness="1.5"
                         Background="#EEF4FF" Padding="10,0"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" FontSize="12" Foreground="#1565C0"
                           FontWeight="SemiBold" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="36" FontSize="13"
                             BorderBrush="#90CAF9" BorderThickness="1.5"
                             Background="#EEF4FF" PasswordChar="●"
                             Margin="0,0,0,24"/>

                <Button Content="Войти"
                        Style="{StaticResource GreenBtn}"
                        Click="LoginButton_Click"
                        Margin="0,0,0,10"/>
                <Button Content="Зарегистрировать нового пользователя"
                        Style="{StaticResource OutlineBtn}"
                        Click="RegisterButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
