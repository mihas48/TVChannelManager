<Window x:Class="TVChannelManager.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TVChannelManager.WPF.Converters"
        Title="TV Channel Manager"
        Height="640" Width="1100"
        MinHeight="500" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#EEF4FF">

    <Window.Resources>
        <local:Base64ToImageConverter x:Key="Base64ToImageConverter"/>

        <!-- остальные стили (BlueBtn, RedBtn и т.д.) – оставь как есть -->

        <Style x:Key="BlueBtn" TargetType="Button">
            <!-- ... -->
        </Style>
        <Style x:Key="RedBtn" TargetType="Button">
            <!-- ... -->
        </Style>
        <Style x:Key="OutlineBtn" TargetType="Button">
            <!-- ... -->
        </Style>
        <Style x:Key="ReportBtn" TargetType="Button">
            <!-- ... -->
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#1565C0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height"     Value="44"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#BBDEFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="10,0" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#0D47A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#1565C0">
            <Border.Effect>
                <DropShadowEffect Color="#0D47A1" BlurRadius="12" ShadowDepth="3" Opacity="0.4"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📺" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="TV Channel Manager"
                               FontSize="17" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="UserLabel"
                           Foreground="#BBDEFB" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Таблица -->
        <Border Grid.Row="1" Margin="20,16,20,0" Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect Color="#1565C0" BlurRadius="12" ShadowDepth="0" Opacity="0.12"/>
            </Border.Effect>
            <DataGrid x:Name="ChannelsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E3EEFF"
                      Background="White"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название"     Binding="{Binding Name}"                                       Width="*"   MinWidth="120"/>
                    <DataGridTextColumn Header="Рейтинг, %"  Binding="{Binding Rating}"                                     Width="90"/>
                    <DataGridTextColumn Header="Ср. возраст" Binding="{Binding MedianViewersAge}"                           Width="90"/>
                    <DataGridTextColumn Header="Дата осн."   Binding="{Binding FoundingDate,     StringFormat=dd.MM.yyyy}"  Width="105"/>
                    <DataGridTextColumn Header="Вещание с"   Binding="{Binding BroadcastStartTime, StringFormat=hh\\:mm}"  Width="85"/>
                    <DataGridCheckBoxColumn Header="HD"      Binding="{Binding IsHD}"                                       Width="50"/>
                    <DataGridTextColumn Header="Жанр"        Binding="{Binding Genre}"                                      Width="130"/>
                    <DataGridTemplateColumn Header="Логотип" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding LogoImage, Converter={StaticResource Base64ToImageConverter}}"
                                       Width="34" Height="34"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Панель кнопок -->
        <Grid Grid.Row="2" Margin="20,14,20,18">
            <Button Content="📄  Сформировать отчёт"
                    Style="{StaticResource ReportBtn}"
                    HorizontalAlignment="Left"
                    Width="195" Padding="0"
                    Click="ReportButton_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="＋  Добавить"
                        Style="{StaticResource BlueBtn}"
                        Padding="18,0" Margin="0,0,8,0"
                        Click="AddButton_Click"/>
                <Button Content="✏️  Редактировать"
                        Style="{StaticResource OutlineBtn}"
                        Padding="18,0" Margin="0,0,8,0"
                        Click="EditButton_Click"/>
                <Button Content="🗑️  Удалить"
                        Style="{StaticResource RedBtn}"
                        Padding="18,0"
                        Click="DeleteButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>