<Window x:Class="TVChannelManager.WPF.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Формирование отчёта"
        Height="540" Width="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF4FF">

    <Window.Resources>
        <Style x:Key="BlueBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1565C0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0A3070"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#90CAF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineBtn" TargetType="Button">
            <Setter Property="Background"      Value="#E3EEFF"/>
            <Setter Property="Foreground"      Value="#1565C0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7"
                                BorderBrush="#90CAF9" BorderThickness="1.5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Шапка -->
        <Border VerticalAlignment="Top" Height="54" Background="#1565C0">
            <TextBlock Text="📄  Формирование отчёта"
                       FontSize="16" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" Margin="22,0"/>
        </Border>

        <!-- Основная область -->
        <Border Margin="20,70,20,20" Background="White" CornerRadius="10" Padding="22,18">
            <Border.Effect>
                <DropShadowEffect Color="#1565C0" BlurRadius="12" ShadowDepth="0" Opacity="0.12"/>
            </Border.Effect>

            <Grid>
                <!-- Панель выбора вида отчёта -->
                <StackPanel x:Name="PanelButtons" VerticalAlignment="Center">
                    <TextBlock Text="Выберите вид отчёта:"
                               FontSize="15" FontWeight="Bold" Foreground="#1565C0"
                               Margin="0,0,0,22"/>

                    <Button Content="📋  Отчёт об одном канале"
                            Style="{StaticResource BlueBtn}"
                            Padding="0" Margin="0,0,0,12"
                            Click="BtnSingleReport_Click"/>

                    <TextBlock Text="Подробная карточка выбранного телеканала"
                               FontSize="11" Foreground="#90A4AE" Margin="4,0,0,20"/>

                    <Button Content="📋  Отчёт по выбранным каналам"
                            Style="{StaticResource BlueBtn}"
                            Padding="0" Margin="0,0,0,12"
                            Click="BtnMultipleReport_Click"/>

                    <TextBlock Text="Список нескольких каналов по вашему выбору"
                               FontSize="11" Foreground="#90A4AE" Margin="4,0,0,20"/>

                    <Button Content="📊  Интегральный отчёт"
                            Style="{StaticResource BlueBtn}"
                            Background="#0D47A1"
                            Padding="0" Margin="0,0,0,12"
                            Click="BtnIntegralReport_Click"/>

                    <TextBlock Text="Статистика: средний рейтинг, распределение по жанрам, доля HD"
                               FontSize="11" Foreground="#90A4AE" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Панель выбора одного канала -->
                <StackPanel x:Name="PanelSingle" Visibility="Collapsed">
                    <TextBlock Text="Выберите канал для отчёта:"
                               FontSize="14" FontWeight="Bold" Foreground="#1565C0"
                               Margin="0,0,0,12"/>
                    <ListBox x:Name="ListSingle"
                             Height="260"
                             BorderBrush="#90CAF9" BorderThickness="1.5"
                             Background="#F5F9FF"
                             FontSize="13"/>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="← Назад"
                                Style="{StaticResource OutlineBtn}"
                                Padding="0" Click="BtnBack_Click"/>
                        <Button Grid.Column="2" Content="Сформировать отчёт"
                                Style="{StaticResource BlueBtn}"
                                Padding="0" Click="BtnGenerateSingle_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Панель выбора нескольких каналов -->
                <StackPanel x:Name="PanelMultiple" Visibility="Collapsed">
                    <TextBlock Text="Отметьте каналы для отчёта:"
                               FontSize="14" FontWeight="Bold" Foreground="#1565C0"
                               Margin="0,0,0,12"/>
                    <ListBox x:Name="ListMultiple"
                             Height="260"
                             BorderBrush="#90CAF9" BorderThickness="1.5"
                             Background="#F5F9FF"
                             SelectionMode="Multiple"
                             FontSize="13">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected,
                                              RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                          Foreground="#1B3A6B" FontSize="13"
                                          Cursor="Hand"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="← Назад"
                                Style="{StaticResource OutlineBtn}"
                                Padding="0" Click="BtnBack_Click"/>
                        <Button Grid.Column="2" Content="Сформировать отчёт"
                                Style="{StaticResource BlueBtn}"
                                Padding="0" Click="BtnGenerateMultiple_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>